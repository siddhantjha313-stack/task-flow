# Root-level Railway/local environment example.
# Copy the relevant keys into Railway variables or server/.env for local API runs.

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/taskflow-ai?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
DEMO_SEED=false

# Optional frontend override when the client is served separately in development.
VITE_API_URL=http://localhost:5000/api
